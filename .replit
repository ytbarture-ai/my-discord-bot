modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Beluga Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Zeeplin Bot"

[[workflows.workflow]]
name = "Beluga Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bots/beluga && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Zeeplin Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bots/zeeplin && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
