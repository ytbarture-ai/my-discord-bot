# Bot token (Discord Developer Portal → Your App → Bot → Token)
BELUGA_TOKEN=your_beluga_bot_token_here

# Application ID (Discord Developer Portal → Your App → General Information → Application ID)
BELUGA_CLIENT_ID=your_beluga_client_id_here

# Optional: Register commands to a specific guild (instant) — remove for global (up to 1h)
GUILD_ID=your_guild_id_here
