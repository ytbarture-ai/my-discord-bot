# Bot token (Discord Developer Portal → Your App → Bot → Token)
ZEEPLIN_TOKEN=your_zeeplin_bot_token_here

# Application ID
ZEEPLIN_CLIENT_ID=your_zeeplin_client_id_here

# Optional: Register commands to a specific guild (instant) — remove for global (up to 1h)
GUILD_ID=your_guild_id_here

# Channel ID to send moderation logs
MOD_LOG_CHANNEL_ID=your_log_channel_id_here
